# ─────────────────────────────────────────────────────────────
# Flower basic auth — PLACEHOLDER
# ─────────────────────────────────────────────────────────────
# This file is a placeholder. The real .htpasswd is generated
# at deploy time by running:
#
#   htpasswd -bc /etc/nginx/.htpasswd admin "$FLOWER_PASSWORD"
#
# Or inside the nginx container:
#
#   docker compose exec nginx sh -c \
#     'apk add --no-cache apache2-utils && htpasswd -bc /etc/nginx/.htpasswd admin "$FLOWER_PASSWORD"'
#
# Make sure FLOWER_PASSWORD is set in your .env file.
# ─────────────────────────────────────────────────────────────
