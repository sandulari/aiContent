# ============================================================
# Shadow Pages — Production Environment Variables
# Copy to ../.env and fill in all values marked CHANGE
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_USER=vre_prod
DB_PASSWORD=  # CHANGE: generate with `openssl rand -hex 32`
POSTGRES_DB=vre
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=  # CHANGE: generate with `openssl rand -hex 32`
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── MinIO (S3-compatible storage) ────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=  # CHANGE: generate with `openssl rand -hex 16`
MINIO_SECRET_KEY=  # CHANGE: generate with `openssl rand -hex 32`
MINIO_SECURE=false

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=  # CHANGE: generate with `openssl rand -hex 64`
JWT_EXPIRATION_HOURS=24

# ── Domain ───────────────────────────────────────────────────
DOMAIN=yourdomain.com
APP_URL=https://yourdomain.com
CORS_ORIGINS=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://yourdomain.com

# ── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=  # CHANGE: get from resend.com
EMAIL_FROM=Shadow Pages <noreply@yourdomain.com>

# ── Instagram ───────────────────────────────────────────────
RAPIDAPI_KEY=  # CHANGE: get from rapidapi.com

# ── AI ──────────────────────────────────────────────────────
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=  # CHANGE: or use Claude bridge below
CLAUDE_BRIDGE_URL=http://host.docker.internal:7777
CLAUDE_BRIDGE_MODEL=sonnet

# ── Flower Admin ────────────────────────────────────────────
FLOWER_PASSWORD=  # CHANGE: password for /flower/ admin panel via nginx htpasswd
