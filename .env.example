# Postgres
DATABASE_URL=postgresql+asyncpg://vre_user:vre_pass@postgres:5432/vre
DB_USER=vre_user
DB_PASSWORD=vre_pass
POSTGRES_DB=vre

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_EXTERNAL_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secret
MINIO_BUCKET_VIDEOS=videos
MINIO_BUCKET_LOGOS=logos
MINIO_BUCKET_AUDIO=audio
MINIO_BUCKET_EXPORTS=exports
MINIO_USE_SSL=false

# Instagram
IG_SESSION_COOKIE=
IG_USERNAME=
IG_PASSWORD=

# Proxy
PROXY_ENABLED=false
PROXY_LIST_URL=

# Search APIs
SERPAPI_KEY=
AUDD_API_KEY=
YOUTUBE_DATA_API_KEY=
TINEYE_API_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Enhancement
GPU_ENABLED=false
REALESRGAN_MODEL=RealESRGAN_x4plus
RIFE_ENABLED=false

# AI Text Generation
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_MODEL=claude-sonnet-4-20250514

# Discovery Config
DISCOVERY_INTERVAL_HOURS=12
DISCOVERY_CANDIDATES_PER_RUN=15
DISCOVERY_HASHTAG_COOLDOWN_HOURS=48
DISCOVERY_GRAPH_CRAWL_BUDGET=10
THEME_PAGE_MIN_HEURISTIC_SCORE=4
QUALITY_GATE_MIN_VIRAL_RATE=0.10

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000

# JWT
JWT_SECRET=change-me-to-random-jwt-secret
JWT_EXPIRATION_HOURS=24

# App Config
DEFAULT_VIEW_THRESHOLD=500000
DEFAULT_SCRAPE_INTERVAL_MINUTES=60
MAX_RESULTS_PER_SCRAPE=50
